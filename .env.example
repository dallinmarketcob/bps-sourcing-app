# ============================================================================
#  Brooks Pest SOLUTIONS (BPS) — instance config TEMPLATE
#
#  Copy this file to `.env` and fill it in:   cp .env.example .env
#  `.env` is gitignored and NEVER committed. This is the only place business-
#  specific values live (plus source_maps/ and secrets/).
#
#  SWEEP RULE: every business-specific key is listed here EXPLICITLY — even when
#  blank — because the code DEFAULTS in src/leadsource/config.py are Brooks Pest
#  CONTROL's values. A blank here is the safe failure mode (that channel just
#  won't run); an OMITTED line silently inherits Brooks's value. Don't delete
#  lines — fill the [TODO ...] placeholders as onboarding proceeds.
#
#  Keep DRY_RUN=true until BPS has reviewed and signed off on a dry-run audit.
# ============================================================================

# --- PestRoutes / FieldRoutes ---
# Their API subdomain, global auth key + token. Confirm the key type is "global".
PESTROUTES_BASE_URL=https://[TODO-bps-subdomain].pestroutes.com/api
PESTROUTES_AUTH_KEY=
PESTROUTES_AUTH_TOKEN=
# Their office IDs, comma-separated (set after probing /office). Search is per-office.
PESTROUTES_OFFICE_IDS=

# --- Meta / Facebook Ads ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
# BPS's PestRoutes source label for Meta instant-form leads (e.g. "Source NN").
META_LEAD_SOURCE=[TODO-bps-meta-source]
# BPS's PestRoutes source label for their main website form.
WEBSITE_FORM_SOURCE=[TODO-bps-website-form-source]
# Meta-beats-near-simultaneous-form tiebreak window in minutes (same rule as Brooks).
META_FORM_TIEBREAK_MINUTES=2

# SINGLE PAGE: set META_PAGE_ID below and put that page's non-expiring token in
# META_ACCESS_TOKEN above. Leave META_PAGES blank.
META_PAGE_ID=
#
# MULTIPLE PAGES (e.g. a DBA brand on its own page): list each page below and
# leave META_PAGE_ID blank. Format per entry: page_id|page_token|source
#   - page_token is OPTIONAL; if omitted, META_ACCESS_TOKEN is used (only works
#     if that token is a USER token with access to every page — a PAGE-scoped
#     token can read only its own page).
#   - source is OPTIONAL; if omitted, META_LEAD_SOURCE is used.
# Mint a non-expiring page token per page with scripts/meta_page_token.py.
# Entries are separated by commas or newlines. Example (two pages, own tokens):
#   META_PAGES=579676868552462|EAA...brooks...|Source NN,894672603731889|EAA...teddys...|Source NN
META_PAGES=

# --- Genesys Cloud ---
# BPS region (e.g. usw2.pure.cloud) — confirm; may differ from Brooks.
GENESYS_REGION=
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
# SALES queue IDs, comma-separated. Include Spanish/secondary SALES queues;
# EXCLUDE customer-service queues. Discover during channel setup.
GENESYS_INSIDE_SALES_QUEUE_ID=

# --- Gmail ---
GMAIL_CREDENTIALS_FILE=secrets/credentials.json
GMAIL_TOKEN_FILE=secrets/token.json
GMAIL_LABEL=form-leads
# BPS lead senders/domains, comma-separated (built during sender discovery).
# Hunt for relay senders too (zapier, make.com). Brooks's list does NOT apply.
GMAIL_LEAD_SENDERS=

# --- Google Ads / Local Services Ads (LSA) ---
# CHECK FIRST: if BPS LSA accounts sit under the SAME Google Ads manager (MCC)
# as Brooks, reuse the dev token + OAuth (just enumerate their customer IDs).
# Otherwise apply for their own dev token + Basic Access immediately (multi-day).
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_API_VERSION=v21
# BPS's PestRoutes source label for LSA leads.
LSA_SOURCE=[TODO-bps-lsa-source]

# --- Engine tunables (attribution model — IDENTICAL to Brooks; already correct) ---
STALE_WINDOW_DAYS=7
SAME_DAY_CLUSTER_HOURS=24
LOOKBACK_DAYS=365
SOURCE_MAPS_DIR=source_maps
MASTER_SHEET=source_maps/sourcing_master.csv
DB_PATH=data/attribution.sqlite
DRY_RUN=true

# Pay-per-lead providers for the weekly dispute report (BPS's list — a decision).
PAY_PER_LEAD_PROVIDERS=

# Protected sources — internal/process sources that must NEVER be overwritten.
# SEEDED from Brooks's generic pest-industry list as a STARTING point; BPS must
# confirm each against their own PestRoutes picklist and add any BPS-specific
# internal sources. Matched case-insensitively on the label.
PROTECTED_SOURCES=Door to Door,Additional Property,Customer Referral,Technician Referral,Customer Service Referral,Refer a Friend Campaign,Upsell,Outbound,Saw our truck,Reactivation Email Campaign,Email Campaign,Inside Sales Renewal,Renewal - In Contract,Renewal - No Contract,Renewal - Out of Contract,Rate Raise Renewal,Bad Debt Renewal,Conditions
