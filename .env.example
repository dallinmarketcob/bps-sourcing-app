# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- PestRoutes / FieldRoutes ---
PESTROUTES_BASE_URL=https://yourcompany.pestroutes.com/api
PESTROUTES_AUTH_KEY=
PESTROUTES_AUTH_TOKEN=
# Global key, but subscription search must be polled one office at a time.
PESTROUTES_OFFICE_IDS=1,2,3,4,5,6,8,9,10

# --- Meta / Facebook Ads ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# --- Genesys Cloud ---
GENESYS_REGION=mypurecloud.com
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
# inside-sales queue to filter on (obtained in Phase 0)
GENESYS_INSIDE_SALES_QUEUE_ID=

# --- Gmail ---
# Path to OAuth client secret + stored token (gitignored)
GMAIL_CREDENTIALS_FILE=secrets/credentials.json
GMAIL_TOKEN_FILE=secrets/token.json
GMAIL_LABEL=form-leads

# --- Engine tunables ---
STALE_WINDOW_DAYS=30
SAME_DAY_CLUSTER_HOURS=24
LOOKBACK_DAYS=90
SOURCE_MAPS_DIR=source_maps
DB_PATH=data/attribution.sqlite
DRY_RUN=true

# Comma-separated provider names that are pay-per-lead (for the dispute report)
PAY_PER_LEAD_PROVIDERS=
